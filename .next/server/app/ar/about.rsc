5:["$","$L11",null,{"dictionary":{"nav":{"home":"الرئيسية","services":"خدماتنا","about":"من نحن","contact":"تواصل معنا","getStarted":"ابدأ الآن"},"hero":{"badge":"الشركة الرائدة في حلول تكنولوجيا المعلومات في ماليزيا","title1":"نبني التميز","title2":"الرقمي","description":"نصمم أنظمة إدارة علاقات العملاء المبتكرة ومنصات إدارة المشاريع والحلول السحابية التي تُحوّل الأعمال وتدفع عجلة النمو.","exploreServices":"استكشف خدماتنا","contactUs":"تواصل معنا","projectsValue":"+50","projectsLabel":"مشروع","clientsValue":"+20","clientsLabel":"عميل","yearsValue":"+4","yearsLabel":"سنوات"},"stats":{"items":[{"value":"+40","label":"شريك عالمي"},{"value":"+2 ألف","label":"متدرب"},{"value":"100%","label":"رضا العملاء"},{"value":"40 ألف","label":"متعلم محترف"}]},"services":{"badge":"خدماتنا","title":"ماذا","titleHighlight":"نقدم","description":"حلول تكنولوجيا معلومات شاملة مصممة للارتقاء بأعمالك إلى المستوى التالي.","learnMore":"اعرف المزيد","items":[{"title":"أنظمة إدارة علاقات العملاء","description":"حلول مخصصة لإدارة علاقات العملاء تعمل على تبسيط مسار المبيعات وتعزيز التفاعل مع العملاء.","features":["أتمتة المبيعات","تتبع العملاء المحتملين","تقارير مخصصة","تكامل API"]},{"title":"إدارة المشاريع","description":"منصات قوية للتخطيط والتتبع وتسليم المشاريع بكفاءة مع أدوات التعاون في الوقت الفعلي.","features":["إدارة المهام","التعاون الجماعي","تتبع التقدم","تخطيط الموارد"]},{"title":"الحلول السحابية والبريد الإلكتروني","description":"بنية تحتية سحابية من AWS على مستوى المؤسسات وحلول بريد إلكتروني احترافية لعمليات سلسة.","features":["إعداد AWS","استضافة البريد الإلكتروني","الأمان","دعم على مدار الساعة"]},{"title":"التدريب والاستشارات","description":"برامج تدريبية يقودها خبراء واستشارات استراتيجية لتمكين فريقك بأحدث المهارات.","features":["تدريب الشركات","ورش العمل","التدريب الفردي","الشهادات"]}]},"about":{"badge":"لماذا تختارنا","title":"صُنع من أجل","titleHighlight":"النجاح","description":"نجمع بين الخبرة التقنية والرؤية التجارية لتقديم حلول ذات قيمة حقيقية.","features":[{"title":"الابتكار أولاً","description":"حلول متطورة مصممة خصيصاً لاحتياجات عملك."},{"title":"أمان المؤسسات","description":"بروتوكولات أمان على مستوى البنوك لحماية بياناتك."},{"title":"تسليم سريع","description":"منهجية أجايل تضمن النشر السريع."},{"title":"نمو قابل للتوسع","description":"حلول تنمو مع نمو أعمالك."}]},"testimonials":{"badge":"آراء العملاء","title":"ماذا يقول","titleHighlight":"عملاؤنا","readMore":"اقرأ المزيد","readLess":"اقرأ أقل","items":[{"name":"المهندس رامي أبو بكر","role":"شركة الرمز لمشاريع البناء | المملكة العربية السعودية","content":"شكري وتقديري الصادق للدكتور طلعت والفريق المرافق للدورة. بصراحة، كانت دورة تدريبية مميزة جداً على المستوى الشخصي. بصدق، لم يكن الهدف فقط اجتياز الامتحان والحصول على الشهادة، بل كان هدفي تعلم وتطبيق إدارة المشاريع في العالم الحقيقي، نظراً لعملنا كمهندسين ومديري مواقع."},{"name":"د. فاتن البعيشي الكيلاني","role":"محاضرة بكلية القانون، جامعة طرابلس | ليبيا","content":"التحقت ببرنامج الدكتور طلعت العوادي التدريبي في إدارة المشاريع الاحترافية، معتقدة أن نطاق المعلومات والمهارات التي سأتلقاها سيكون خارج نطاق البرنامج. تساءلت عن الفوائد التي يمكنني اكتسابها من تخصص بعيد جداً عن هذا البرنامج التدريبي، كما كنت أعتقد سابقاً. اكتشفت لاحقاً، أثناء محاضراتي في كليات القانون بالجامعات الليبية، أنني اكتسبت مهارات عديدة ومهمة صقلت أسلوبي في العطاء والتقديم."},{"name":"فيصل الشبحي","role":"مدير، أمانة جدة","content":"شكراً جزيلاً للمدرب طلعت العوادي على هذه الدورة (إدارة المشاريع الاحترافية). لقد لعبت دوراً كبيراً في توسيع فهمي ومعرفتي بإدارة المشاريع، ومعالجة سيناريوهات العالم الحقيقي بحكمة وإدارة فعالة — وهو نهج يحقق فوائد عملية عديدة. كما أتقدم بالشكر لفريق مركز دار الإبداع على جهودهم المتميزة، وكذلك لزملائي المتدربين؛ كان من دواعي سروري العمل والتعاون معهم طوال الدورة."}]},"contact":{"badge":"تواصل معنا","title":"لنبنِ شيئاً","titleHighlight":"مذهلاً","description":"هل أنت مستعد لتحويل عملك؟ تواصل معنا ودعنا نناقش كيف يمكننا مساعدتك في تحقيق أهدافك.","emailLabel":"راسلنا","phoneLabel":"اتصل بنا","visitLabel":"زُرنا","emailValue":"info@creativity-house.com","phoneValue":"+60 3-1234 5678","visitValue":"كوالالمبور، ماليزيا","form":{"name":"الاسم الكامل","namePlaceholder":"محمد أحمد","email":"البريد الإلكتروني","emailPlaceholder":"mohammed@company.com","subject":"الموضوع","subjectPlaceholder":"كيف يمكننا مساعدتك؟","message":"الرسالة","messagePlaceholder":"أخبرنا عن مشروعك...","send":"إرسال الرسالة","sending":"جارٍ الإرسال...","sent":"تم إرسال الرسالة!"}},"footer":{"description":"نمكّن الشركات بحلول تكنولوجيا المعلومات المبتكرة والبرمجيات المخصصة والتدريب المتخصص منذ عام 2015.","servicesTitle":"الخدمات","contactTitle":"التواصل","serviceLinks":["أنظمة CRM","إدارة المشاريع","الحلول السحابية","التدريب"],"legal":{"copyright":"© 2026 دار الإبداع. جميع الحقوق محفوظة.","privacy":"سياسة الخصوصية","terms":"شروط الخدمة"}},"languageSwitcher":{"label":"English"},"about_page":{"hero":{"badge":"من نحن","title1":"دار الإبداع —","titleHighlight":"نبني مستقبل المنظمات","description":"دار الإبداع المحدودة شركة متعددة الجنسيات متخصصة في التدريب والاستشارات وحلول التقنية، تعمل في مجالات التطوير الإداري وتمكين القيادات وإدارة المشاريع والتحول الرقمي. تأسست عام 2014 واتخذت من سيبرجايا بماليزيا مقراً لها منذ عام 2017، ونمت لتكون شريكاً موثوقاً للمؤسسات في منطقة الشرق الأوسط وأفريقيا وجنوب شرق آسيا.","stats":[{"value":"+10","label":"سنوات خبرة"},{"value":"+17","label":"دولة حول العالم"},{"value":"3","label":"مراكز عمليات إقليمية"}],"vision":{"title":"رؤيتنا","text":"أن نكون الخيار الأول عالمياً في مجال التطوير الإداري والقيادي، وتمكين الأفراد والمؤسسات من تحقيق النجاح المستدام والأثر الملموس."},"mission":{"title":"رسالتنا","text":"تقديم خدمات تدريبية واستشارية مبتكرة وعملية وقائمة على التقنية، تعمل على تطوير الكفاءات البشرية وتعزيز الأداء المؤسسي وتسريع التبني الرقمي في المنظمات الحديثة."}},"social_proof":{"badge":"موثوقون عالمياً","title":"شراكات مع","titleHighlight":"منظمات عالمية رائدة","description":"من كبرى شركات الطاقة العالمية إلى الجامعات المرموقة، تثق المؤسسات في دار الإبداع لتطوير كوادرها البشرية وتحويل مسيرتها المؤسسية.","testimonials":[{"name":"د. فاتن البعيشي الكيلاني","role":"محاضرة بكلية القانون — جامعة طرابلس، ليبيا","quote":"اكتسبت مهارات عديدة وعميقة عززت بشكل كبير أسلوبي في تقديم المحتوى. كل الشكر للمهندس طلعت العوادي."},{"name":"م. رامي أبو بكر","role":"شركة الرمز لمشاريع البناء — المملكة العربية السعودية","quote":"مشروع متأخر تحوّل إلى تحفة معمارية، والانتقادات صارت ثناءً صادقاً."},{"name":"م. فتحي الجهضمي — مستشار هندسي","role":"مستشار هندسي","quote":"أنصح بشدة كل من يسعى لفهم إدارة المشاريع بالالتحاق بهذا البرنامج الشامل."},{"name":"أ. فيصل الشبحي","role":"مدير، أمانة جدة","quote":"أسهم إسهاماً كبيراً في توسيع معرفتي وفهمي لإدارة المشاريع."},{"name":"د. أسامة ويدان","role":"متخصص رفيع المستوى","quote":"المحتوى العلمي يستحق وزنه ذهباً. أنا الآن مرشح لمنصب المدير التنفيذي."}]},"trainer":{"badge":"المدرب","title":"تعرف على","titleHighlight":"الخبير صاحب التميز","name":"م. طلعت العوادي","jobTitle":"مدرب دولي في القيادة والإدارة وإدارة المشاريع","bio_label":"السيرة الذاتية","bio":"المهندس طلعت حسن العوادي مدرب دولي معتمد وخبير في مجالات الإدارة والقيادة وتنمية المهارات، يمتلك خبرة مثرية تمتد لأكثر من 20 عاماً في تقديم برامج تدريبية متخصصة للمؤسسات الحكومية والخاصة في الشرق الأوسط وأفريقيا وجنوب شرق آسيا.","credentials_label":"المؤهلات الأكاديمية","credentials":["بكالوريوس هندسة البترول","ماجستير إدارة الأعمال (MBA)","مرشح لنيل درجة الدكتوراه في إدارة التقنية"],"expertise_label":"مجالات الخبرة","expertise":["إدارة المشاريع","القيادة والتدريب","التخطيط الاستراتيجي"],"badges":["+20 عاماً","مدرب معتمد","خبرة دولية"]}}},"lang":"ar"}]
